{
  "expo": {
    "name": "MatchSlot",
    "slug": "MatchSlot",
    "version": "1.9.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "matchslot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C130F"
    },
    "locales": {
      "en": "./locales/en.json",
      "de": "./locales/de.json",
      "fr": "./locales/fr.json",
      "it": "./locales/it.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matchslot.app",
      "buildNumber": "24",
      "userInterfaceStyle": "automatic",
      "infoPlist": {
        "CFBundleLocalizations": ["en", "de", "fr", "it"],
        "CFBundleDevelopmentRegion": "en",
        "NSCameraUsageDescription": "This app does not use the camera.",
        "NSPhotoLibraryUsageDescription": "This app does not access your photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIUserInterfaceStyle": "Automatic",
        "NSUserNotificationsUsageDescription": "We notify you when matches are booked or approved.",
        "NSCalendarsUsageDescription": "MatchSlot can add your booked matches to your calendar.",
        "NSCalendarsFullAccessUsageDescription": "MatchSlot can add your booked matches to your calendar.",
        "LSApplicationQueriesSchemes": [
          "whatsapp"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0C130F"
      },
      "userInterfaceStyle": "automatic",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.matchslot.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-mail-composer",
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "MatchSlot needs access to your calendar to add match events."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65a8eca0-e2ec-4b0d-aa80-0180cdd13da7"
      }
    }
  }
}
